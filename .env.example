# =============================================================================
# WorkForceAI — Environment Variables (TEMPLATE)
# -----------------------------------------------------------------------------
# Copy this file to ".env" and replace the placeholder values with real ones.
# The real ".env" file is git-ignored and must NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (Express + MySQL) — read by server/config.js
# -----------------------------------------------------------------------------

# Port the API server listens on. Optional — defaults to 5000 if omitted.
PORT=5000

# MySQL host. Optional — defaults to "localhost" if omitted.
DB_HOST=localhost

# MySQL port. Optional — defaults to 3306 if omitted.
DB_PORT=3306

# MySQL username. REQUIRED.
DB_USER=your_mysql_user

# MySQL password. REQUIRED.
DB_PASSWORD=your_mysql_password

# MySQL database name. REQUIRED. (The app's SQL expects this schema.)
DB_NAME=workforce_ai

# -----------------------------------------------------------------------------
# Frontend (Vite / React) — must be prefixed with VITE_ to be exposed
# -----------------------------------------------------------------------------

# Base URL the frontend uses to reach the backend API.
# Should match the backend host/port above.
VITE_API_BASE_URL=http://localhost:5000